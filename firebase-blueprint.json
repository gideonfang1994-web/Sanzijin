{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and statistics",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "xp": { "type": "number" },
        "level": { "type": "number" },
        "streak": { "type": "number" },
        "starCoins": { "type": "number" },
        "magicCoins": { "type": "number" },
        "totalWordsLearned": { "type": "number" },
        "masteredWords": { "type": "array" },
        "wordMastery": { "type": "object" },
        "bestChallengeScore": { "type": "number" },
        "rank": { "type": "number" },
        "hearts": { "type": "number" },
        "maxCombo": { "type": "number" },
        "selectedCharacterId": { "type": "string" },
        "equippedItems": { "type": "object" },
        "unlockedItems": { "type": "array" },
        "completedLevelsCount": { "type": "number" },
        "completedLevelIds": { "type": "array" },
        "characterStats": { "type": "object" },
        "lastLogin": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["uid", "xp", "level"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Store for user profiles and progress"
    }
  }
}
